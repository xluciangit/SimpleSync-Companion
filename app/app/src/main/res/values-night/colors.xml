    <color name="md_theme_surface">#1E2130</color>
    <color name="md_theme_onSurface">#E2E8F0</color>

    <!-- Surface variant: inner boxes, code blocks — deeper #171923 -->
    <color name="md_theme_surfaceVariant">#171923</color>
