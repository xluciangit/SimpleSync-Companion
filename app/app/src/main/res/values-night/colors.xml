    <color name="md_theme_primary">#3B82F6</color>
    <color name="md_theme_onPrimary">#FFFFFF</color>
    <!-- Primary container: the blue-tinted card border/highlight area -->
    <color name="md_theme_primaryContainer">#1E3A5F</color>
    <color name="md_theme_onPrimaryContainer">#BFDBFE</color>

    <color name="md_theme_secondary">#94A3B8</color>
    <color name="md_theme_onSecondary">#13151C</color>
    <color name="md_theme_secondaryContainer">#1E2130</color>
